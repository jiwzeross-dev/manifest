{
  "manifest_version": 3,
  "name": "Kubdee AutoGen v3.1.6",
  "version": "3.1.6",
  "key": "",
  "description": "สร้างภาพและวิดีโอโฆษณาด้วย AI พร้อมโพสต์ปักตระกร้า TikTok อัตโนมัติ",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob:; object-src 'self'"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "icons": {
    "16": "logo/kubdee.png",
    "48": "logo/kubdee.png",
    "128": "logo/kubdee.png"
  },
  "permissions": ["sidePanel", "scripting", "activeTab", "tabs", "storage", "downloads", "unlimitedStorage", "identity", "windows", "browsingData", "offscreen", "clipboardRead", "clipboardWrite"],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Click to open sidebar",
    "default_icon": {
      "16": "logo/kubdee.png",
      "48": "logo/kubdee.png",
      "128": "logo/kubdee.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "assets/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://autogen.kubdee.com/editor*",
        "http://localhost:3000/editor*",
        "http://localhost:3001/editor*"
      ],
      "js": [
        "assets/editorBridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
